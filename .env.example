# 🍳 ChefIA - Configurações

# ── Mensageiros ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
WHATSAPP_API_URL=https://sua-instancia.evolution-api.com
WHATSAPP_API_KEY=sua_chave_evolution_aqui
WHATSAPP_INSTANCE=nome-da-instancia
# FIX: Secret para validação de assinatura do webhook WhatsApp
WHATSAPP_WEBHOOK_SECRET=sua_chave_secreta_para_webhook

# ── Inteligência Artificial (LLMs) ───────────────────────────────────
AIOS_DEFAULT_MODEL=gemini-3.1-pro-preview
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-gemini-key-for-vision-here

# ── Persistência Nuvem (Supabase) ────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# FIX: Use EXCLUSIVAMENTE a ANON_KEY (chave pública com RLS habilitado)
# NUNCA use SERVICE_ROLE_KEY no runtime do bot — ela bypassa RLS
SUPABASE_ANON_KEY=your-supabase-anon-key-here
# DATABASE_URL (Legado pg puro - opcional se usar apenas SDK Supabase)
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# ── Admin & Segurança ───────────────────────────────────────────────
ADMIN_SECRET=sua_senha_admin_segura_aqui
PORT=3000
