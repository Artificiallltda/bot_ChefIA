# ============================================
# ChefIA - Recipe Search Engine
# Configuração de Variáveis de Ambiente
# ============================================

# Google Gemini API
# Obter em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
# Obter em: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Logging Configuration (opcional)
LOG_LEVEL=INFO

# Database Configuration (opcional, se usar conexão direta)
# DATABASE_URL=postgresql://user:password@localhost:5432/database

# Recipe Search Configuration (opcional)
# MAX_RESULTS=10
# SIMILARITY_THRESHOLD=0.5
# EMBEDDING_MODEL=models/text-embedding-004
