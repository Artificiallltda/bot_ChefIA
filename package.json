{
  "name": "@synkra/chefia-core",
  "version": "2.0.0",
  "description": "ChefIA Core Intelligence - Gastronomic Math & Nutrition",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "start": "ts-node src/index.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "dotenv": "^17.3.1",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^6.25.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node-telegram-bot-api": "^0.64.13",
    "@types/pg": "^8.11.2",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
